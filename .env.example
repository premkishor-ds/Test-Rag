# Database Connection Configuration
POSTGRES_SERVER=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=stock_rag
POSTGRES_PORT=5432

# Vector DB Configuration
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# Local Ollama AI Infrastructure Configuration
